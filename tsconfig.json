{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@static": ["ressources/static"],
      "@config": ["ressources/static/config"],
      "@map": ["ressources/static/map"]
    },
    "outDir": "dist/",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "strict": false,
    "downlevelIteration": true,
    "target": "es6",
    "allowJs": true,
  },
  "include": [
        "src/**/*"
    ],
  "exclude": [
		"node_modules",
        "dist"
	]
}